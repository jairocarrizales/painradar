# ─── PainRadar environment ───
# Copy to .env.local and fill in what you need. Mock mode needs NOTHING.

# Which engine analyzes complaints into ranked opportunities:
#   mock          → deterministic demo data, no keys, instant (default)
#   claude-agent  → a local Claude agent using YOUR Claude subscription (no API key)
#   openrouter    → OpenRouter API, pay-per-token
AI_PROVIDER=mock

# ─── claude-agent mode (recommended for personal use) ───
# Runs an autonomous Claude agent on YOUR machine using YOUR Claude subscription.
# It web-searches Reddit/YouTube itself — no Reddit/YouTube/OpenRouter keys needed.
#
# 1. Install Claude Code and log in:  npm i -g @anthropic-ai/claude-code  &&  claude
# 2. Generate a long-lived subscription token:  claude setup-token
# 3. Paste it below and set AI_PROVIDER=claude-agent
CLAUDE_CODE_OAUTH_TOKEN=
# Optional tuning:
# PAINRADAR_AGENT_MODEL=sonnet          # opus | sonnet | haiku | full model id
# PAINRADAR_AGENT_MAX_TURNS=20
# PAINRADAR_AGENT_TIMEOUT_MS=240000

# ─── openrouter mode (optional, pay-per-token) ───
OPENROUTER_API_KEY=
# Needs pre-collected complaints from the source APIs below:
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=painradar/0.1 by your_username
YOUTUBE_API_KEY=

# ─── Storage ───
# This is a single-user, local app: no login, no external DB.
# Favorites and cached searches live in a local SQLite file (./data/painradar.db).
# Optional: change where that file lives.
# PAINRADAR_DATA_DIR=
