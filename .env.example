# Pega aquí tu token de Claude (genéralo con:  claude setup-token)
CLAUDE_CODE_OAUTH_TOKEN=

# (Opcional) Para usar YouTube de verdad (leer comentarios reales):
# tu API key de "YouTube Data API v3" (gratis, en console.cloud.google.com)
# YOUTUBE_API_KEY=

# (Opcional) GitHub Issues funciona SIN token; agrega uno solo para más límite de
# peticiones (gratis, en github.com/settings/tokens, sin permisos especiales).
# GITHUB_TOKEN=

# (Opcional) Solo si usas la app en MODO DESARROLLO desde otros equipos de tu red:
# pon aquí TU IP local (la ves con  ipconfig / ifconfig). Ej:
# LAN_IP=192.168.1.50
# En modo producción (iniciar-en-red.bat) NO hace falta.
